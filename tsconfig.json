{
    "compilerOptions": {
        "jsx": "react-jsx",
        "skipLibCheck": true,
        "module": "ESNext",
        "noImplicitAny": true,
        "outDir": "./dist/",
        "lib": ["ESNext", "dom", "dom.iterable"],
        "esModuleInterop": true,
        "sourceMap": true,
        "strict": true,
        "target": "ES6",
        "moduleResolution": "bundler",
        "baseUrl": ".",
        "paths": {
            "@components/*": ["src/components/*"],
            "@pages/*": ["src/pages/*"],
            "@assets/*": ["src/assets/*"],
            "@firebase-utils/*": ["src/firebase/*"],
            "src/*": ["src/*"]
        }
    },
    "include": ["src"],
    "exclude": ["node_modules"]
}
