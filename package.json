{
    "name": "magnusrand",
    "version": "1.0.0",
    "description": "Portefolio website for Magnus Rand",
    "main": "index.js",
    "author": "Magnus Rand",
    "license": "ISC",
    "private": "true",
    "engines": {
        "node": ">=22"
    },
    "scripts": {
        "clean": "rm -rf dist/",
        "eslint": "eslint src --ext 'js,jsx,ts,tsx'",
        "format": "prettier . --write",
        "format:check": "prettier . --check",
        "lint": "npm run eslint && npm run stylelint && npm run format:check",
        "start": "webpack serve",
        "local": "webpack serve --env development",
        "build-dev": "webpack --mode development",
        "build-prod": "npm run clean && webpack --mode production"
    },
    "dependencies": {
        "animate-css-grid": "^1.4.3",
        "classnames": "^2.5.1",
        "exifr": "^7.1.3",
        "firebase": "^11.0.0",
        "react": "^18.3.0",
        "react-dom": "^18.3.0",
        "react-icons": "^5.3.0",
        "react-router-dom": "^6.28.0"
    },
    "devDependencies": {
        "@babel/core": "^7.16.0",
        "@babel/preset-env": "^7.16.4",
        "@babel/preset-react": "^7.16.0",
        "@svgr/webpack": "^6.2.1",
        "@types/react": "^18.3.0",
        "@types/react-dom": "^18.3.0",
        "@typescript-eslint/eslint-plugin": "^8.0.0",
        "@typescript-eslint/parser": "^8.0.0",
        "autoprefixer": "^10.4.0",
        "babel-loader": "^8.2.3",
        "css-loader": "^7.1.2",
        "eslint": "^8.57.0",
        "eslint-import-resolver-typescript": "^3.7.0",
        "eslint-plugin-import": "^2.24.2",
        "eslint-plugin-prettier": "^5.0.0",
        "eslint-plugin-react": "^7.27.1",
        "eslint-plugin-react-hooks": "^4.2.0",
        "html-webpack-plugin": "^5.5.0",
        "postcss": "^8.4.49",
        "postcss-loader": "^8.1.1",
        "postcss-nested": "^7.0.2",
        "postcss-preset-env": "^7.0.1",
        "prettier": "^3.0.0",
        "style-loader": "^4.0.0",
        "ts-loader": "^9.5.1",
        "typescript": "^5.7.2",
        "webpack": "^5.97.0",
        "webpack-cli": "^6.0.0",
        "webpack-dev-server": "^5.2.0"
    },
    "prettier": {
        "trailingComma": "all",
        "tabWidth": 4,
        "semi": false,
        "singleQuote": true
    },
    "stylelint": {
        "extends": [
            "stylelint-config-standard",
            "stylelint-config-prettier"
        ],
        "rules": {
            "at-rule-no-unknown": [
                true,
                {
                    "ignoreAtRules": [
                        "extend",
                        "at-root",
                        "debug",
                        "warn",
                        "error",
                        "if",
                        "else",
                        "for",
                        "each",
                        "while",
                        "mixin",
                        "include",
                        "content",
                        "return",
                        "function"
                    ]
                }
            ],
            "no-descending-specificity": [
                true,
                {
                    "severity": "warning"
                }
            ]
        }
    }
}